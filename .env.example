# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=0
DISCORD_REGISTER_COMMANDS_GLOBALLY=false
DISCORD_TIME_ZONE_ID=SE Asia Standard Time

# Database (optional)
BOT_DB_CONNECTION_STRING=Data Source=project-manager-bot.db

# GitHub tracking (optional, dùng cho repo private hoặc tăng rate limit)
GITHUB_TRACKING_ENABLED=true
GITHUB_TOKEN=
GITHUB_POLL_INTERVAL_SECONDS=60
GITHUB_MAX_COMMITS_PER_POLL=10

# Assistant AI (optional, cần bật Message Content Intent trong Discord Developer Portal)
ASSISTANT_ENABLED=true
ASSISTANT_API_KEY=
ASSISTANT_BASE_URL=https://api.openai.com/v1/
ASSISTANT_MODEL=gpt-4.1-mini
ASSISTANT_TEMPERATURE=0.2
ASSISTANT_MAX_RECENT_MESSAGES=12
ASSISTANT_MAX_STANDUP_DAYS=3
ASSISTANT_MAX_ATTENTION_ITEMS=8
ASSISTANT_MEMORY_LOOKBACK_DAYS=30
ASSISTANT_MEMORY_DIGEST_DAYS=7
ASSISTANT_MAX_RELEVANT_MEMORY_MESSAGES=6
ASSISTANT_MAX_DAILY_MEMORY_DIGESTS=7

# Lavalink (optional, defaults shown below)
LAVALINK_BASE_ADDRESS=http://127.0.0.1:2333/
LAVALINK_WEBSOCKET_URI=ws://127.0.0.1:2333/v4/websocket
LAVALINK_PASSPHRASE=youshallnotpass
LAVALINK_LABEL=main
LAVALINK_READY_TIMEOUT_SECONDS=20
